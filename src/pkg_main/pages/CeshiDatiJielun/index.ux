<template>
  <div class="root-wrap">
    <list class="page-list">
      <!-- 顶部背景区 -->
      <list-item type="header" class="header-item">
        <div class="header-area">
          <image class="header-bg" src="/pkg_main/assets/img/shoujibizhi-bg-1.png"></image>
          <div class="nav-bar">
            <div class="back-btn" onclick="goBack">
              <image class="back-icon" src="/pkg_main/assets/img/back.png"></image>
            </div>
            <text class="nav-title">{{pageTitle}}</text>
          </div>
          <div class="header-gradient"></div>
        </div>
      </list-item>

      <!-- 雷达图卡片 -->
      <list-item type="radar-card" class="card-item">
        <div class="radar-card-wrap">
          <div class="blur-layer"></div>
          <div class="frost-overlay"></div>
          <div class="white-card">
            <!-- 结论 tag -->
            <div class="tag-row">
              <div class="result-tag">
                <text class="result-tag-text">结论</text>
              </div>
            </div>
            <!-- 雷达图 Canvas -->
            <div class="canvas-wrap">
              <canvas id="radarCanvas" class="radar-canvas"></canvas>
            </div>
          </div>
        </div>
      </list-item>

      <!-- 结果块 1 -->
      <list-item type="section-0" class="section-item">
        <div class="result-section">
          <text class="section-title">{{sectionTitle1}}</text>
          <text class="section-body">{{sectionBody1}}</text>
        </div>
      </list-item>

      <!-- 结果块 2 -->
      <list-item type="section-1" class="section-item" if="{{showMultiResult}}">
        <div class="result-section">
          <text class="section-title">{{sectionTitle2}}</text>
          <text class="section-body">{{sectionBody2}}</text>
        </div>
      </list-item>

      <!-- 结果块 3 -->
      <list-item type="section-2" class="section-item" if="{{showMultiResult}}">
        <div class="result-section">
          <text class="section-title">{{sectionTitle3}}</text>
          <text class="section-body">{{sectionBody3}}</text>
        </div>
      </list-item>

      <!-- 底部安全留白 -->
      <list-item type="spacer" class="spacer-item">
        <div style="width: 250px; height: 88px;"></div>
      </list-item>
    </list>

    <!-- 底部按钮栏（固定） -->
    <div class="bottom-bar">
      <div class="btn-retry" onclick="retry">
        <text class="btn-text">重新测试</text>
      </div>
      <div class="btn-home" onclick="goHome">
        <text class="btn-text">返回首页</text>
      </div>
    </div>
  </div>
</template>

<script>
import router from '@system.router'
import { mentalHealthTest } from '../../helper/JS/xinlizhuangtai'
import { depressionAssessment } from '../../helper/JS/yiyufengxian'
import { anxietyAssessment } from '../../helper/JS/jiaolu'

export default {
  data() {
    return {
      testName: '',
      catTitle: '',
      pageTitle: '测评结果',
      showMultiResult: true,
      sectionTitle1: '💯结果',
      sectionBody1: '暂无结果',
      sectionTitle2: '📌说明',
      sectionBody2: '请重新测试',
      sectionTitle3: '📝备注',
      sectionBody3: '测试仅供参考',
      // 雷达图5维度模拟数据（0~1归一化）
      // 顺序: fruity, bitter, heavy, strong, sunny
      series1: [0.62, 0.68, 0.52, 0.45, 0.58],  // 粉色/红色系（当前状态）
      series2: [0.88, 0.92, 0.76, 0.82, 0.95],   // 黄色系（参考値）
      series3: [0.50, 0.55, 0.60, 0.48, 0.65]    // 米色/肤色系（心理状态）
    }
  },
  onInit() {
    try {
      if (this.$page && this.$page.query) {
        const q = this.$page.query
        if (q.testName) this.testName = q.testName
        if (q.catTitle) this.catTitle = q.catTitle
        const answers = q.answers ? String(q.answers).split(',').map(Number) : []
        this.computeResult(answers)
      }
    } catch (e) {
      this.pageTitle = '测评结果'
      this.sectionTitle1 = '💯结果'
      this.sectionBody1 = '结果解析失败：' + String(e.message || e)
      this.sectionTitle2 = '📌说明'
      this.sectionBody2 = '请重新测试'
      this.sectionTitle3 = '📝备注'
      this.sectionBody3 = '测试仅供参考'
    }
  },
  parseRange(rangeText) {
    const text = String(rangeText || '').replace('分', '')
    const arr = text.split('-').map(Number)
    return { min: arr[0] || 0, max: arr[1] || 0 }
  },
  pickByRange(list, score) {
    if (!list || !list.length) return null
    for (let i = 0; i < list.length; i++) {
      const rg = this.parseRange(list[i].scoreRange)
      if (score >= rg.min && score <= rg.max) return list[i]
    }
    return list[list.length - 1]
  },
  sumByOptionValue(questions, answers) {
    let total = 0
    for (let i = 0; i < questions.length; i++) {
      const q = questions[i]
      const idx = answers[i]
      if (idx === undefined || idx < 0 || idx > 3) continue
      const opt = q.options[idx]
      total += (opt && typeof opt.value === 'number') ? opt.value : (idx + 1)
    }
    return total
  },
  computeResult(answers) {
    const name = this.testName || this.catTitle
    this.pageTitle = name || '测评结果'

    if (name === '心理状态测试') {
      const qs = mentalHealthTest.questions || []
      const scores = { depression: 0, anxiety: 0, interpersonal: 0 }
      for (let i = 0; i < qs.length; i++) {
        const q = qs[i]
        const idx = answers[i]
        if (idx === undefined || idx < 0 || idx > 3) continue
        scores[q.dimension] += (idx + 1)
      }

      const dep = this.pickByRange(mentalHealthTest.conclusions.depression, scores.depression)
      const anx = this.pickByRange(mentalHealthTest.conclusions.anxiety, scores.anxiety)
      const inter = this.pickByRange(mentalHealthTest.conclusions.interpersonal, scores.interpersonal)

      this.sectionTitle1 = '😞抑郁'
      this.sectionBody1 = `得分：${scores.depression}分\n等级：${dep ? dep.level : '暂无'}\n${dep ? dep.desc : ''}`
      this.sectionTitle2 = '😟焦虑'
      this.sectionBody2 = `得分：${scores.anxiety}分\n等级：${anx ? anx.level : '暂无'}\n${anx ? anx.desc : ''}`
      this.sectionTitle3 = '👥人际关系敏感'
      this.sectionBody3 = `得分：${scores.interpersonal}分\n等级：${inter ? inter.level : '暂无'}\n${inter ? inter.desc : ''}`

      const dn = Math.max(0, Math.min(1, (scores.depression - 11) / 33))
      const an = Math.max(0, Math.min(1, (scores.anxiety - 11) / 33))
      const inn = Math.max(0, Math.min(1, (scores.interpersonal - 10) / 30))
      this.series1 = [dn, an, inn, (dn + an) / 2, (an + inn) / 2]
      this.showMultiResult = true
      return
    }

    if (name === '抑郁风险评估') {
      const total = this.sumByOptionValue(depressionAssessment.questions || [], answers)
      const risk = depressionAssessment.getRiskLevel(total) || {}
      this.sectionTitle1 = '😞抑郁风险评估'
      this.sectionBody1 = `总分：${total}分\n等级：${risk.level || '暂无'}\n${risk.conclusion || risk.error || ''}`
      this.sectionTitle2 = '📊评分规则'
      this.sectionBody2 = depressionAssessment.scoringRule || ''
      this.sectionTitle3 = '📌备注'
      this.sectionBody3 = depressionAssessment.remark || ''
      const n = Math.max(0, Math.min(1, (total - 25) / 75))
      this.series1 = [n, n, n, n, n]
      this.showMultiResult = false
      return
    }

    if (name === '焦虑测试') {
      const total = this.sumByOptionValue(anxietyAssessment.questions || [], answers)
      const risk = anxietyAssessment.getRiskLevel(total) || {}
      this.sectionTitle1 = '😟焦虑测试'
      this.sectionBody1 = `总分：${total}分\n等级：${risk.level || '暂无'}\n${risk.conclusion || risk.error || ''}`
      this.sectionTitle2 = '📊评分规则'
      this.sectionBody2 = anxietyAssessment.scoringRule || ''
      this.sectionTitle3 = '📌备注'
      this.sectionBody3 = anxietyAssessment.remark || ''
      const n = Math.max(0, Math.min(1, (total - 25) / 75))
      this.series1 = [n, n, n, n, n]
      this.showMultiResult = false
      return
    }

    this.sectionTitle1 = '💯结果'
    this.sectionBody1 = '未匹配到测试类型，请重新测试。'
    this.sectionTitle2 = '📌说明'
    this.sectionBody2 = ''
    this.sectionTitle3 = '📝备注'
    this.sectionBody3 = ''
    this.showMultiResult = false
  },
  onReady() {
    const self = this
    setTimeout(function () {
      try {
        self.drawRadar()
      } catch (e) {}
    }, 100)
  },
  drawRadar() {
    const canvas = this.$element('radarCanvas')
    if (!canvas) return
    const ctx = canvas.getContext('2d')
    if (!ctx) return

    const W = 220
    const H = 190
    const cx = W / 2       // 110
    const cy = H / 2 - 4  // 91
    const R = 58            // 最大半径
    const N = 5             // 五边形
    const LAYERS = 4        // 同心层数
    const labels = ['fruity', 'bitter', 'heavy', 'strong', 'sunny']

    // ---- 辅助：获取第i个顶点的角度 ----
    function angle(i) {
      return -Math.PI / 2 + (2 * Math.PI * i) / N
    }
    function ptX(r, i) { return cx + r * Math.cos(angle(i)) }
    function ptY(r, i) { return cy + r * Math.sin(angle(i)) }

    // ---- 清画布 ----
    ctx.clearRect(0, 0, W, H)

    // ---- 绘制网格背景（圆形） ----
    for (let l = 1; l <= LAYERS; l++) {
      const lr = R * l / LAYERS
      ctx.beginPath()
      ctx.arc(cx, cy, lr, 0, 2 * Math.PI)
      ctx.closePath()
      ctx.strokeStyle = '#e0e0e0'
      ctx.lineWidth = 1
      ctx.stroke()
    }

    // ---- 绘制轴线 ----
    ctx.strokeStyle = '#d8d8d8'
    ctx.lineWidth = 1
    for (let i = 0; i < N; i++) {
      ctx.beginPath()
      ctx.moveTo(cx, cy)
      ctx.lineTo(ptX(R, i), ptY(R, i))
      ctx.stroke()
    }

    // ---- 绘制黄色系（外层参考） ----
    const s2 = this.series2
    ctx.beginPath()
    for (let i = 0; i < N; i++) {
      const x = ptX(R * s2[i], i)
      const y = ptY(R * s2[i], i)
      if (i === 0) ctx.moveTo(x, y)
      else ctx.lineTo(x, y)
    }
    ctx.closePath()
    ctx.fillStyle = 'rgba(255, 218, 40, 0.22)'
    ctx.fill()
    ctx.strokeStyle = '#f5c800'
    ctx.lineWidth = 1
    ctx.stroke()
    // 黄色顶点圆点
    for (let i = 0; i < N; i++) {
      ctx.beginPath()
      ctx.arc(ptX(R * s2[i], i), ptY(R * s2[i], i), 3, 0, 2 * Math.PI)
      ctx.fillStyle = '#f5c800'
      ctx.fill()
    }

    // ---- 绘制粉色系（当前状态） ----
    const s1 = this.series1
    ctx.beginPath()
    for (let i = 0; i < N; i++) {
      const x = ptX(R * s1[i], i)
      const y = ptY(R * s1[i], i)
      if (i === 0) ctx.moveTo(x, y)
      else ctx.lineTo(x, y)
    }
    ctx.closePath()
    ctx.fillStyle = 'rgba(255, 100, 80, 0.18)'
    ctx.fill()
    ctx.strokeStyle = '#f56050'
    ctx.lineWidth = 1
    ctx.stroke()
    // 粉色顶点圆点
    for (let i = 0; i < N; i++) {
      ctx.beginPath()
      ctx.arc(ptX(R * s1[i], i), ptY(R * s1[i], i), 3, 0, 2 * Math.PI)
      ctx.fillStyle = '#f56050'
      ctx.fill()
    }

    // ---- 绘制米色系（心理状态） ----
    const s3 = this.series3
    ctx.beginPath()
    for (let i = 0; i < N; i++) {
      const x = ptX(R * s3[i], i)
      const y = ptY(R * s3[i], i)
      if (i === 0) ctx.moveTo(x, y)
      else ctx.lineTo(x, y)
    }
    ctx.closePath()
    ctx.fillStyle = 'rgba(224, 176, 144, 0.18)'
    ctx.fill()
    ctx.strokeStyle = '#e0b090'
    ctx.lineWidth = 1
    ctx.stroke()
    // 米色顶点圆点
    for (let i = 0; i < N; i++) {
      ctx.beginPath()
      ctx.arc(ptX(R * s3[i], i), ptY(R * s3[i], i), 3, 0, 2 * Math.PI)
      ctx.fillStyle = '#e0b090'
      ctx.fill()
    }
    const labelR = R + 16
    ctx.fillStyle = '#555555'
    ctx.font = '9px sans-serif'
    for (let i = 0; i < N; i++) {
      const lx = cx + labelR * Math.cos(angle(i))
      const ly = cy + labelR * Math.sin(angle(i))
      // 根据位置设置对齐
      if (i === 0) ctx.textAlign = 'center'
      else if (i === 1) ctx.textAlign = 'left'
      else if (i === 2) ctx.textAlign = 'left'
      else if (i === 3) ctx.textAlign = 'right'
      else ctx.textAlign = 'right'

      ctx.textBaseline = 'middle'
      ctx.fillText(labels[i], lx, ly)
    }
  },
  goBack() {
    router.back()
  },
  retry() {
    router.replace({
      uri: '/pkg_main/pages/CeshiDatiPage',
      params: { testName: this.testName, catTitle: this.catTitle }
    })
  },
  goHome() {
    router.clear()
    router.replace({ uri: '/pkg_main/pages/Main' })
  }
}
</script>

<style>
.root-wrap {
  flex: 1;
  flex-direction: column;
  width: 250px;
  background-color: #f5f5f5;
}

/* 列表 */
.page-list {
  flex: 1;
  width: 250px;
}

/* 顶部背景区 */
.header-item {
  width: 250px;
}
.header-area {
  width: 250px;
  height: 155px;
  position: relative;
  flex-direction: column;
}
.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 250px;
  height: 155px;
  object-fit: cover;
}
.nav-bar {
  position: absolute;
  top: 20px;
  left: 0;
  width: 250px;
  height: 44px;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  padding: 0 12px;
}
.back-btn {
  width: 22px;
  height: 22px;
  border-radius: 11px;
  background-color: rgba(255, 255, 255, 0.3);
  align-items: center;
  justify-content: center;
}
.back-icon {
  width: 6px;
  height: 10px;
  object-fit: contain;
}
.nav-title {
  font-size: 11px;
  font-weight: bold;
  color: #1a1a1a;
  margin-left: 6px;
}
.character-img {
  position: absolute;
  right: 0;
  bottom: -8px;
  width: 120px;
  height: 145px;
  object-fit: contain;
}
.header-gradient {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 250px;
  height: 55px;
  background: linear-gradient(to bottom, rgba(255,255,255,0) 0%, rgba(255,255,255,0.92) 100%);
}

/* 雷达图卡片 */
.card-item {
  width: 250px;
  margin-top: -40px;
}
.radar-card-wrap {
  width: 234px;
  margin: 0 8px;
  position: relative;
  overflow: hidden;
  border-top-left-radius: 22px;
  border-top-right-radius: 22px;
  flex-direction: column;
  padding-top: 12px;
}
.blur-layer {
  display: none;
}
.frost-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 234px;
  height: 100%;
  border-top-left-radius: 22px;
  border-top-right-radius: 22px;
  background: linear-gradient(
    to bottom,
    rgba(255, 255, 255, 0.60) 0%,
    rgba(255, 255, 255, 1.0) 20%,
    rgba(255, 255, 255, 1.0) 100%
  );
}
.white-card {
  width: 234px;
  border-radius: 14px;
  background-color: transparent;
  flex-direction: column;
  padding: 10px 0 8px 0;
  position: relative;
}
.tag-row {
  flex-direction: row;
  padding: 0 14px;
  margin-bottom: 6px;
}
.result-tag {
  background-color: rgba(255, 100, 30, 0.12);
  border-radius: 6px;
  padding: 4px 10px;
}
.result-tag-text {
  font-size: 11px;
  color: #ff6420;
  font-weight: bold;
}
.canvas-wrap {
  width: 234px;
  height: 190px;
  align-items: center;
  justify-content: center;
}
.radar-canvas {
  width: 220px;
  height: 190px;
}

/* 结果分区 */
.section-item {
  width: 250px;
}
.result-section {
  width: 234px;
  margin: 10px 8px 0 8px;
  background-color: #ffffff;
  border-radius: 14px;
  padding: 16px 0;
  flex-direction: column;
}
.section-title {
  font-size: 11px;
  font-weight: bold;
  color: #1a1a1a;
  margin: 0 16px 6px 16px;
}
.section-body {
  font-size: 9px;
  color: #333333;
  line-height: 16px;
  margin: 0 16px;
}

/* 底部空白 */
.spacer-item {
  width: 250px;
}

/* 底部按钮栏 */
.bottom-bar {
  position: absolute;
  bottom: 0px;
