  justify-content: center;
}
.btn-home {
  width: 96px;
  height: 36px;
  border-radius: 18px;
  background-color: #28c060;
  align-items: center;
  justify-content: center;
}
.btn-text {
  font-size: 12px;
  color: #ffffff;
  font-weight: bold;
}
</style>
