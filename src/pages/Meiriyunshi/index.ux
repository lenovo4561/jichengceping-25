    <!-- 日期行 -->
    <list-item type="date-row" class="date-item">
      <div class="date-row">
        <div class="date-bar"></div>
        <text class="date-text">{{dateStr}}</text>
      </div>
    </list-item>

    <!-- 运势分区：循环渲染 -->
    <list-item type="section" class="section-item" for="{{(idx, sec) in sections}}">
      <div class="fortune-section">
        <text class="sec-title">{{sec.icon}}{{sec.title}}</text>
        <text class="sec-body">{{sec.body}}</text>
