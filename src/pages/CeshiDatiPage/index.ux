  border-radius: 8px;
  border-width: 1px;
  border-style: solid;
  padding: 10px 8px;
  justify-content: flex-start;
  margin-right: 7px;
}
.opt-normal {
  border-color: #e0e0e0;
  background-color: #f9f9f9;
}
