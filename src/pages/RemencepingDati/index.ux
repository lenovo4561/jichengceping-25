}
.opt-nor {
  border-color: #e0e0e0;
  background-color: #f9f9f9;
}
.opt-sel {
  border-color: #28c060;
  background-color: rgba(40, 192, 96, 0.08);
}
.opt-text {
  font-size: 11px;
  color: #333333;
}
.opt-text-sel {
  color: #28c060;
  font-weight: bold;
}
/* 底部按钮 */
.bottom-bar {
  width: 250px;
