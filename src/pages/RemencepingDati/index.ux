<template>
  <div class="page-wrapper">
    <!-- 顶部背景区 -->
    <div class="header-area">
      <image class="header-bg" src="/assets/img/remencepingdati-bg.png"></image>
      <div class="nav-bar">
        <div class="back-btn" onclick="goBack">
          <image class="back-icon" src="/assets/img/back.png"></image>
        </div>
        <div style="width: 22px;"></div>
      </div>
    </div>

    <!-- 白色内容面板 -->
    <div class="content-panel">
      <div class="frost-overlay"></div>
      <div class="panel-content">
      <!-- 第 X 题 badge -->
      <div class="q-badge">
        <text class="q-badge-text">第 {{currentIdx + 1}} 题</text>
      </div>
      <!-- 题目文字 -->
      <text class="q-text">{{currentQ.question}}</text>
      <!-- 四个选项，纵向排列 -->
      <div class="option-item {{answers[currentIdx] === 0 ? 'opt-sel' : 'opt-nor'}}" onclick="selectOpt(0)">
        <text class="opt-text {{answers[currentIdx] === 0 ? 'opt-text-sel' : ''}}">A.{{currentQ.opts[0]}}</text>
      </div>
      <div class="option-item {{answers[currentIdx] === 1 ? 'opt-sel' : 'opt-nor'}}" onclick="selectOpt(1)">
        <text class="opt-text {{answers[currentIdx] === 1 ? 'opt-text-sel' : ''}}">B.{{currentQ.opts[1]}}</text>
      </div>
      <div class="option-item {{answers[currentIdx] === 2 ? 'opt-sel' : 'opt-nor'}}" onclick="selectOpt(2)">
        <text class="opt-text {{answers[currentIdx] === 2 ? 'opt-text-sel' : ''}}">C.{{currentQ.opts[2]}}</text>
      </div>
      <div class="option-item {{answers[currentIdx] === 3 ? 'opt-sel' : 'opt-nor'}}" onclick="selectOpt(3)">
        <text class="opt-text {{answers[currentIdx] === 3 ? 'opt-text-sel' : ''}}">D.{{currentQ.opts[3]}}</text>
      </div>
      </div>
    </div>

    <!-- 底部按钮 -->
    <div class="bottom-bar">
      <div class="next-btn" onclick="nextOrResult">
        <text class="next-btn-text">{{isLast ? '查看结论' : '下一题'}}</text>
      </div>
    </div>
  </div>
</template>

<script>
import router from '@system.router'

export default {
  data() {
    return {
      catTitle: '心理状态',
      testName: '心理状态测试',
      currentIdx: 0,
      answers: [-1, -1, -1, -1, -1],
      questions: [
        {
          question: '在《西游记》中，会七十二变的人是谁？',
          opts: ['孙悟空', '唐僧', '猪八戒', '沙悟净']
        },
        {
          question: '我觉得闷闷不乐，情绪低沉',
          opts: ['无/偶尔有', '有时有', '经常有', '总是如此']
        },
        {
          question: '我觉得一天之中早晨最好',
          opts: ['无/偶尔有', '有时有', '经常有', '总是如此']
        },
        {
          question: '我感到精力充沛，干劲十足',
          opts: ['无/偶尔有', '有时有', '经常有', '总是如此']
        },
        {
          question: '我容易感到心烦意乱，难以平静',
          opts: ['无/偶尔有', '有时有', '经常有', '总是如此']
        }
      ]
    }
  },
  computed: {
    currentQ() {
      return this.questions[this.currentIdx]
    },
    isLast() {
      return this.currentIdx === this.questions.length - 1
    }
  },
  onInit() {
    if (this.$page && this.$page.query) {
      const q = this.$page.query
      if (q.catTitle) this.catTitle = q.catTitle
      if (q.testName) this.testName = q.testName
    }
  },
  goBack() {
    router.back()
  },
  selectOpt(optIdx) {
    const newAnswers = this.answers.slice()
    newAnswers[this.currentIdx] = optIdx
    this.answers = newAnswers
  },
  nextOrResult() {
    if (this.answers[this.currentIdx] === -1) return
    if (this.isLast) {
      router.replace({
        uri: '/pages/RemencepingJielun',
        params: { answers: this.answers.join(',') }
      })
    } else {
      this.currentIdx = this.currentIdx + 1
    }
  }
}
</script>

